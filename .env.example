# cn-scraper-mcp local dev configuration
# Copy this to .env and fill in your paths.
# .env is gitignored — never committed.

# === Cookie files (JSON exports from logged-in browser) ===
# Each engine looks for its cookie file at:
#   1. The env var below (if set)
#   2. ~/.ecom-cookies/<name>.json (default)
#
# To get cookies: DevTools → Application → Cookies → export as JSON,
# or use Chrome CDP Network.getAllCookies for httponly cookies.

TAOBAO_COOKIES_FILE=
XHS_COOKIES_FILE=
ZHIHU_COOKIES_FILE=
ZSXQ_COOKIES_FILE=

# === Chrome (optional — for JD, XHS engines) ===
# CHROME_PATH=
